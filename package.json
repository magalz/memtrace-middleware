{
  "name": "@memtrace/middleware",
  "version": "1.0.0",
  "description": "Memtrace Agent Middleware — structural code intelligence layer for AI coding agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "memtrace": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ && prettier --check .",
    "lint:fix": "eslint src/ tests/ --fix && prettier --write .",
    "typecheck": "tsc --noEmit",
    "test:load": "k6 run load/ring-buffer-stress.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "memtrace",
    "agent",
    "middleware",
    "mcp",
    "code-intelligence"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "chokidar": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.15.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.29.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.0"
  }
}
