{
  "name": "@memtrace/middleware",
  "version": "0.1.0",
  "description": "Memtrace Agent Middleware — structural code intelligence layer for AI coding agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ && prettier --check .",
    "lint:fix": "eslint src/ tests/ --fix && prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "memtrace",
    "agent",
    "middleware",
    "mcp",
    "code-intelligence"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "chokidar": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.0"
  }
}
